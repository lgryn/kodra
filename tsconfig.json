{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Node",
    "declaration": true,
    "baseUrl": "./src",
    "paths": {
      "@config/*": ["infrastructure/config/*"],
      "@cli/*": ["cli/*"],
      "@app/*": ["app/*"],
      "@domain/*": ["domain/*"],
      "@infra/*": ["infrastructure/*"],
      "@shared/*": ["shared/*"]
    },
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  }
}
